# Chave da API da Anthropic (console.anthropic.com) — usada em /api/analisar e /api/perguntar
ANTHROPIC_API_KEY=sk-ant-...

# --- Autenticação (Auth.js v5 + Google OAuth) — FASE 4a ---
# Credenciais do cliente OAuth (Google Cloud Console → APIs e Serviços → Credenciais)
AUTH_GOOGLE_ID=xxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-...
# Segredo para assinar as sessões JWT: gere com `openssl rand -base64 33`
AUTH_SECRET=...
# URL base (dev); em produção a Vercel define automaticamente (trustHost)
AUTH_URL=http://localhost:3040

# --- Banco de dados (Supabase / Postgres) — FASE 4b (ainda não usado no código) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Segredo dos crons (backup diário + saúde dos conectores) — a Vercel envia
# automaticamente como "Authorization: Bearer <CRON_SECRET>" nas execuções agendadas
CRON_SECRET=um-valor-aleatorio-longo

# --- Notificações diárias (módulo de alertas) ---
# E-mail via Resend (resend.com) — o domínio do remetente precisa ser verificado lá
RESEND_API_KEY=re_...
RESEND_FROM="S-Aggregator <alertas@seudominio.com.br>"
# WhatsApp via Cloud API oficial da Meta (business-initiated exige template aprovado)
WHATSAPP_TOKEN=EAA...
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_TEMPLATE=resumo_diario_oportunidades
WHATSAPP_TEMPLATE_LANG=pt_BR
